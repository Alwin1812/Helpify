<?php
// Google API Configuration - TEMPLATE
// Rename this to google_config.php and fill in your keys

$client_id = getenv('GOOGLE_CLIENT_ID');
$client_secret = getenv('GOOGLE_CLIENT_SECRET');

if (!$client_id) {
    $client_id = 'YOUR_GOOGLE_CLIENT_ID';
}

if (!$client_secret) {
    $client_secret = 'YOUR_GOOGLE_CLIENT_SECRET';
}

define('GOOGLE_CLIENT_ID', $client_id);
define('GOOGLE_CLIENT_SECRET', $client_secret);

$protocol = (isset($_SERVER['HTTPS']) && $_SERVER['HTTPS'] === 'on') ? "https" : "http";
$host = $_SERVER['HTTP_HOST'];
define('GOOGLE_REDIRECT_URL', $protocol . "://" . $host . "/helpify/api/google_callback.php");
?>
